PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/newztable?retryWrites=true&w=majority

# NewsData.io — https://newsdata.io  (free tier, commercial use permitted, 200 credits/day)
NEWSDATA_API_KEY=

# The Guardian Open Platform — https://open-platform.theguardian.com  (free, commercial use with attribution)
GUARDIAN_API_KEY=

# How often the background job pulls fresh articles (minutes)
NEWS_FETCH_INTERVAL_MINUTES=15

# Comma-separated origins allowed to call this API (web app domain, localhost during dev)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:5500

# Firebase Cloud Messaging server key (mobile push notifications — wired up later)
FCM_SERVER_KEY=
